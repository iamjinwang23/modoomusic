# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js (monorepo: match at any depth, e.g. apps/web/.next)
.next/
# 심링크(.next → .next.nosync, iCloud 우회)도 무시 — 디렉토리 전용 .next/ 로는 심링크가 안 걸림
.next
# 어느 깊이든(apps/web/.next.nosync). 루트고정 /.next.nosync/ 로는 안 걸렸음
.next.nosync/
out/

# 에디터 임시/스왑 파일
*.swp
*.swo
*~

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.gstack/

# bkit PDCA state (local)
.bkit/
.bkit-memory.json
/.next.nosync/

# 로컬 일회성 시드/유틸 스크립트 (서비스 롤 키 하드코딩 — 커밋 금지)
apps/web/scripts/seed-kpop-posts.mjs
apps/web/scripts/fix-comment-count.mjs
# 기획 아티팩트(앱 무관)
/community-plan.html
.obsidian/
